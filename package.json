{
  "name": "discord-bot",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "register": "tsx src/deploy-commands.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "lint": "biome check src test",
    "format": "biome check --write src test"
  },
  "dependencies": {
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.2",
    "@snazzah/davey": "^0.1.12",
    "better-sqlite3": "^12.2.0",
    "cheerio": "^1.0.0",
    "discord.js": "^14.16.0",
    "ffmpeg-static": "^5.2.0",
    "libsodium-wrappers": "^0.7.15",
    "puppeteer-core": "^25.3.0",
    "undici": "^8.8.0",
    "youtube-dl-exec": "^3.0.10"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@discordjs/opus",
      "better-sqlite3",
      "esbuild",
      "ffmpeg-static",
      "youtube-dl-exec"
    ]
  }
}
