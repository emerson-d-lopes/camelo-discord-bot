# Discord Developer Portal -> your app -> Bot -> Reset Token
DISCORD_TOKEN=

# Discord Developer Portal -> your app -> General Information -> Application ID
CLIENT_ID=

# Optional: your server ID. If set, slash commands deploy instantly to that
# server only (good for dev). If empty, commands deploy globally (takes up to
# an hour to propagate).
GUILD_ID=

# Price watcher default check interval in minutes (default 30; per-watch override via /watch interval)
CHECK_INTERVAL_MINUTES=30

# Optional: lock /stats to a single Discord user id (on top of admin-only).
OWNER_ID=

# Optional local stats dashboard. Off unless STATS_PORT is set. Binds to
# 127.0.0.1 (local only) by default — open http://127.0.0.1:<port> on the host,
# or tunnel in over SSH. STATS_HOST=0.0.0.0 exposes it on the network; set a
# STATS_TOKEN if you do. Endpoints: / (HTML), /metrics (JSON), /prometheus.
STATS_PORT=
STATS_HOST=127.0.0.1
STATS_TOKEN=

# Local Ollama — powers /ask, /summarize, chat, and music-channel intent
# classification. Everything runs locally; no cloud AI.
# Running in Docker? The container's 127.0.0.1 is NOT the host — use
# http://host.docker.internal:11434 (docker-compose sets this for you).
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b

# Bigger model used for open conversation (better recall). Must be pulled in
# Ollama: `ollama pull gemma4:12b`.
ASSISTANT_MODEL=gemma4:12b

# Path to a Chrome/Chromium binary for price-watcher screenshots. Leave empty on
# desktop (Chrome is auto-detected); the Docker image sets it to /usr/bin/chromium.
PUPPETEER_EXECUTABLE_PATH=
